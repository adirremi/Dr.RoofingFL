---
import '../index.css';
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import dmSerifLatinUrl from '@fontsource/dm-serif-display/files/dm-serif-display-latin-400-normal.woff2?url';
import Header from '../components/Header';
import Footer from '../components/Footer';
import StickyMobileCTA from '../components/StickyMobileCTA';

interface Schema {
  '@context'?: string;
  '@type'?: string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description: string;
  canonical: string; // e.g. "/", "/about", "/hollywood-roofing"
  keywords?: string;
  image?: string;
  type?: 'website' | 'article';
  schema?: Schema | Schema[];
  noindex?: boolean;
  /** When true, render <article> hint via og:type=article */
  publishedDate?: string;
  modifiedDate?: string;
}

const SITE = 'https://drroofingflorida.com';

const {
  title,
  description,
  canonical,
  keywords,
  image,
  type = 'website',
  schema,
  noindex = false,
  publishedDate,
  modifiedDate,
} = Astro.props;

const fullUrl = canonical.startsWith('http') ? canonical : `${SITE}${canonical}`;
const ogImage = image
  ? image.startsWith('http')
    ? image
    : `${SITE}${image}`
  : `${SITE}/og-image.jpg`;

const schemas: Schema[] = schema
  ? Array.isArray(schema)
    ? schema
    : [schema]
  : [];

// Sitewide JSON-LD: Organization + WebSite + RoofingContractor
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE}/#organization`,
  name: 'Dr. Roofing FL',
  legalName: 'Dr. Roofing FL LLC',
  url: `${SITE}/`,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE}/logo_512.png`,
    width: 600,
    height: 600,
  },
  image: `${SITE}/logo_512.png`,
  telephone: '+1-754-310-5557',
  email: 'info@drroofingflorida.com',
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Florida State Contractor License',
    value: 'CCC1337611',
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'license',
    name: 'Florida Certified Roofing Contractor',
    identifier: 'CCC1337611',
    recognizedBy: {
      '@type': 'GovernmentOrganization',
      name: 'Florida Department of Business and Professional Regulation (DBPR)',
      url: 'https://www.myfloridalicense.com/',
    },
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '3951 SW 41st St',
    addressLocality: 'Hollywood',
    addressRegion: 'FL',
    postalCode: '33023',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.facebook.com/Drroofingfl',
    'https://www.instagram.com/drroofingfl',
    'https://www.yelp.com/biz/dr-roofing-fl-hollywood',
    'https://www.bbb.org/us/fl/hollywood/profile/roofing-contractors/dr-roofing-fl',
    'https://www.houzz.com/pro/drroofingfl',
    'https://www.angi.com/companylist/us/fl/hollywood/dr-roofing-fl.htm',
    'https://nextdoor.com/pages/dr-roofing-fl-hollywood-fl',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  url: `${SITE}/`,
  name: 'Dr. Roofing FL',
  publisher: { '@id': `${SITE}/#organization` },
  inLanguage: 'en-US',
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  '@id': `${SITE}/#localbusiness`,
  name: 'Dr. Roofing FL',
  alternateName: 'Dr Roofing FL',
  url: `${SITE}/`,
  image: [
    `${SITE}/logo_512.png`,
    `${SITE}/tile_roofing.webp`,
    `${SITE}/metal_roofing.webp`,
    `${SITE}/shingle_roofing.webp`,
    `${SITE}/flat_roofing.webp`,
  ],
  logo: `${SITE}/logo_512.png`,
  telephone: '+1-754-310-5557',
  email: 'info@drroofingflorida.com',
  priceRange: '$$',
  description:
    'Florida State-Certified roofing contractor (License #CCC1337611) — fully licensed and insured — serving Hollywood, Miami, Fort Lauderdale, Palm Beach, Boca Raton, and all of Broward, Palm Beach & Miami-Dade Counties.',
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Florida State Contractor License',
    value: 'CCC1337611',
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'license',
    name: 'Florida Certified Roofing Contractor',
    identifier: 'CCC1337611',
    recognizedBy: {
      '@type': 'GovernmentOrganization',
      name: 'Florida Department of Business and Professional Regulation (DBPR)',
      url: 'https://www.myfloridalicense.com/',
    },
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '3951 SW 41st St',
    addressLocality: 'Hollywood',
    addressRegion: 'FL',
    postalCode: '33023',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 26.0112014,
    longitude: -80.2088724,
  },
  hasMap: 'https://maps.google.com/maps?q=Dr.+Roofing+FL+Hollywood+FL+33023',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '07:00',
      closes: '19:00',
    },
  ],
};

const sitewideSchemas = [orgSchema, websiteSchema, localBusinessSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#ea580c" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Dr. Roofing FL" />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta
        name="robots"
        content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
      />
    )}
    <meta name="googlebot" content="index, follow" />
    <link rel="canonical" href={fullUrl} />

    {/* Geo */}
    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Hollywood, Florida" />
    <meta name="geo.position" content="26.0112014;-80.2088724" />
    <meta name="ICBM" content="26.0112014, -80.2088724" />

    {/* Open Graph */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Dr. Roofing FL" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@drroofingfl" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Favicon — ICO + PNG (WebP is unreliable in SERP/crawlers; /favicon.ico is the standard discovery path) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {/* LCP preload — only on pages that actually use the hero image as LCP */}
    {Astro.url.pathname === '/' && (
      <link rel="preload" as="image" href="/hero_lcp.webp" type="image/webp" fetchpriority="high" />
    )}

    {/* Critical fonts — preload latin subset so FCP/LCP text doesn't wait */}
    <link rel="preload" as="font" type="font/woff2" href={interLatinUrl} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={dmSerifLatinUrl} crossorigin="anonymous" />

    <link rel="dns-prefetch" href="https://maps.google.com" />

    {/* Sitewide JSON-LD */}
    {sitewideSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    {/* Per-page JSON-LD */}
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <style is:inline set:html={`
      @font-face {
        font-family: 'Inter Variable';
        font-style: normal;
        font-display: swap;
        font-weight: 100 900;
        src: url('${interLatinUrl}') format('woff2-variations');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'DM Serif Display';
        font-style: normal;
        font-display: swap;
        font-weight: 400;
        src: url('${dmSerifLatinUrl}') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      html { scroll-behavior: smooth; }
      body { font-family: 'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif; margin: 0; background: #ffffff; color: #0f172a; }
      img { max-width: 100%; height: auto; }
    `} />
  </head>
  <body class="min-h-screen bg-white flex flex-col">
    <Header client:idle />
    <main class="flex-grow pb-14 md:pb-0">
      <slot />
    </main>
    <Footer />
    <StickyMobileCTA client:idle />
  </body>
</html>
