---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectPage from '../ProjectPage';
import { projectsBySlug } from '../../data/projects';

const SITE = 'https://drroofingflorida.com';

export async function getStaticPaths() {
  const { projectsBySlug } = await import('../../data/projects');
  return Object.values(projectsBySlug).map((p) => ({
    params: { slug: p.slug },
    props: { slug: p.slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const project = projectsBySlug[slug];

const title = project.metaTitle || `${project.title} | Dr. Roofing FL Project`;
const description = project.metaDescription || project.summary;
const canonical = project.path || `/projects/${project.slug}`;

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'Project',
  name: project.title,
  description,
  image: `${SITE}${project.image}`,
  url: `${SITE}${canonical}`,
  location: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: project.city,
      addressRegion: 'FL',
      addressCountry: 'US',
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${SITE}/projects` },
    { '@type': 'ListItem', position: 3, name: project.title, item: `${SITE}${canonical}` },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={project.image}
  type="article"
  schema={[projectSchema, breadcrumbSchema]}
>
  <ProjectPage project={project} client:visible />
</BaseLayout>
